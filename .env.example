# Comma-separated NVIDIA NIM API keys (from build.nvidia.com). Each key is an
# independent 40 RPM lane; five keys = 200 RPM aggregate.
NIM_API_KEYS=nvapi-xxxx,nvapi-yyyy

# Everything below is optional.

# Upstream base URL.
#NIM_BASE_URL=https://integrate.api.nvidia.com

# Port the proxy listens on.
#PORT=8000

# Per-key rate limit (requests per rolling 60s). NIM's free tier is ~40.
#RPM_PER_KEY=40

# Max total time to wait for an upstream slot / ride out 429s per request.
#MAX_WAIT_SECS=900

# Interval between SSE keepalive comments while a request is waiting.
#HEARTBEAT_SECS=10

# How long to cache /v1/models so harness catalog polls cost no rate budget.
#MODELS_TTL_SECS=600

# Log verbosity, e.g. nim_proxy=debug
#RUST_LOG=nim_proxy=info
